{{ define "loki.exception.email.subject" -}}
[TradeSignal PROD] ⚠️ {{ .Alerts | len }} exception alert(s) detected — action required
{{- end }}

{{ define "loki.exception.email.html" -}}
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body  { font-family: Arial, sans-serif; font-size: 14px; color: #333; background: #f5f5f5; margin: 0; padding: 0; }
    .wrap { max-width: 700px; margin: 24px auto; background: #fff; border-radius: 6px;
            border-left: 5px solid #e53935; box-shadow: 0 2px 6px rgba(0,0,0,.1); }
    .hdr  { background: #e53935; color: #fff; padding: 18px 24px; border-radius: 2px 2px 0 0; }
    .hdr h1 { margin: 0; font-size: 20px; }
    .hdr p  { margin: 4px 0 0; font-size: 13px; opacity: .85; }
    .body { padding: 20px 24px; }
    .pod-card { border: 1px solid #e0e0e0; border-radius: 5px; margin-bottom: 20px;
                background: #fff; overflow: hidden; }
    .pod-hdr  { background: #fbe9e7; padding: 10px 16px; border-bottom: 1px solid #e0e0e0; }
    .pod-name { font-size: 15px; font-weight: bold; color: #b71c1c; font-family: monospace; }
    .pod-count { font-size: 12px; color: #666; margin-top: 2px; }
    .pod-body { padding: 14px 16px; }
    .lbl  { font-size: 11px; font-weight: bold; text-transform: uppercase;
            color: #888; letter-spacing: .5px; margin-bottom: 4px; margin-top: 10px; }
    .lbl:first-child { margin-top: 0; }
    .val  { font-size: 14px; color: #333; }
    .btn  { display: inline-block; margin-top: 12px; margin-right: 8px; padding: 8px 16px;
            background: #1565c0; color: #fff !important; text-decoration: none !important;
            border-radius: 4px; font-size: 13px; font-weight: bold; }
    .btn-sec { background: #546e7a; }
    .note { font-size: 12px; color: #888; margin-top: 8px; font-style: italic; }
    .exc-type { font-family: monospace; font-size: 15px; font-weight: bold; color: #b71c1c; background: #fff3f3; padding: 4px 8px; border-radius: 3px; display: inline-block; }
    .ftr  { font-size: 11px; color: #aaa; padding: 12px 24px 18px; border-top: 1px solid #eee; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="hdr">
    <h1>⚠ Application Exceptions Detected</h1>
    <p>TradeSignal Production &mdash; Top {{ .Alerts | len }} exception type(s) &mdash; {{ (index .Alerts 0).StartsAt.Format "Mon Jan 2 15:04 UTC 2006" }}</p>
  </div>
  <div class="body">
    {{ range .Alerts }}
    <div class="pod-card">
      <div class="pod-hdr">
        <div class="pod-name">{{ .Labels.exception_type }}</div>
        <div class="pod-count">{{ .Annotations.count }} occurrence(s) &sdot; {{ .Labels.pod }}</div>
      </div>
      <div class="pod-body">
        <div class="lbl">Exception Type</div>
        <div class="val exc-type">{{ .Labels.exception_type }}</div>

        <div class="lbl">Occurrences (last 30 min)</div>
        <div class="val">{{ .Annotations.count }}</div>

        <div class="lbl">Pod</div>
        <div class="val" style="font-family:monospace;font-size:13px">{{ .Labels.pod }}</div>

        <div class="lbl">Detected</div>
        <div class="val">{{ .StartsAt.Format "Mon Jan 2 15:04:05 UTC 2006" }}</div>

        <div class="lbl">View in Grafana (opens exact log lines for this exception)</div>
        <div>
          <a class="btn" href="https://grafana.tradesignalglobal.com/explore?orgId=1&left=%7B%22queries%22%3A%5B%7B%22expr%22%3A%22%7Bnamespace%3D%5C%22tradesignal%5C%22%2Cpod%3D%5C%22{{ .Labels.pod }}%5C%22%7D%20%7C%3D%20%5C%22{{ .Labels.exception_type }}%5C%22%22%2C%22queryType%22%3A%22range%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D">
            {{ .Labels.exception_type }} in {{ .Labels.pod }} ↗
          </a>
          <a class="btn btn-sec" href="https://grafana.tradesignalglobal.com/explore?orgId=1&left=%7B%22queries%22%3A%5B%7B%22expr%22%3A%22%7Bnamespace%3D%5C%22tradesignal%5C%22%7D%20%7C%3D%20%5C%22Exception%5C%22%22%2C%22queryType%22%3A%22range%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-6h%22%2C%22to%22%3A%22now%22%7D%7D">
            All namespace exceptions ↗
          </a>
        </div>
        <div class="note">
          Time range is 6 hours — links will show logs even if this email arrived late.
        </div>
      </div>
    </div>
    {{ end }}
  </div>
  <div class="ftr">Generated by TradeSignal Alertmanager &mdash; do not reply to this email.</div>
</div>
</body>
</html>
{{- end }}
